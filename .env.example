NVIDIA_API_KEY=isi_api_key_nvidia_kamu_di_sini
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model utama stabil untuk logic/katalog.
PRIMARY_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Model copywriting khusus proposal, sales, caption, dan narasi presentasi.
# Rekomendasi awal:
COPYWRITER_MODEL=minimaxai/minimax-m2.7

# Model untuk arahan visual / struktur presentasi.
# Boleh sama dengan copywriter agar tidak terlalu berat.
DESIGN_MODEL=minimaxai/minimax-m2.7

# Model teknis untuk prompt Codex, planning website, dan reviewer teknis.
# Paling aman tetap Nemotron dulu. Kalau endpoint kuat, bisa ganti ke model coding/reasoning lain.
TECHNICAL_MODEL=nvidia/nemotron-3-nano-30b-a3b
